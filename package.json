{
  "name": "trilium-llm-wiki-mcp",
  "version": "0.2.0",
  "description": "MCP server + LLM-wiki skill for Trilium/TriliumNext Notes (Karpathy LLM-wiki methodology).",
  "type": "module",
  "license": "MIT",
  "author": "DragonQi",
  "homepage": "https://github.com/DragonQi/trilium-llm-wiki-mcp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DragonQi/trilium-llm-wiki-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/DragonQi/trilium-llm-wiki-mcp/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "trilium",
    "triliumnext",
    "llm-wiki",
    "knowledge-management",
    "claude",
    "karpathy",
    "etapi"
  ],
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "trilium-llm-wiki-mcp": "dist/index.js",
    "trilium-mcp": "dist/index.js",
    "trilium-wiki": "dist/cli/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "skill",
    "scripts",
    ".mcp.json",
    "docker-compose.yml",
    ".env.example",
    "NOTICE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "prepare": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "graphology": "^0.26.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.1.0"
  }
}

